# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Django ────────────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-generate-a-real-key

DEBUG=True

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank in local dev to use SQLite automatically.
# In production (Render), this is set automatically from the linked database.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Hosts (production only) ───────────────────────────────────────────────────
# Space-separated: "myapp.onrender.com localhost"
ALLOWED_HOSTS=localhost 127.0.0.1

# Space-separated: "https://myapp.onrender.com"
CSRF_TRUSTED_ORIGINS=

# ── Backend Intelligence Engine (Celery + Redis) ──────────────────────────────
# Leave blank in local dev to use a plain local Redis instance
# (redis-server on localhost:6379 — the standard homebrew/apt default).
# In production, set to your Render Redis instance's internal connection URL.
REDIS_URL=

# Run `celery -A ecoiq worker --loglevel=info` in a separate terminal/process
# to actually execute queued tasks. Leave CELERY_TASK_ALWAYS_EAGER unset/False
# unless you specifically want .delay()/.apply_async() to run inline without
# a worker (e.g. a one-off script) — the test suite does not depend on this.
CELERY_TASK_ALWAYS_EAGER=False
