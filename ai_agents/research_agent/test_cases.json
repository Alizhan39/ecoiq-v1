{
  "agent_name": "Research Agent",
  "realistic_test_cases": [
    {
      "id": "RA-01",
      "title": "Kazakhstan coal-fired district heating operator",
      "input": {
        "company_name": "Almaty District Heating Co.",
        "country": "Kazakhstan",
        "sector": "heating and boilers",
        "user_question": "What has this company publicly stated about its coal-to-gas transition plans?"
      },
      "expected_output": {
        "evidence_summary_includes": ["publicly stated transition timeline", "fuel mix disclosure"],
        "confidence": "medium",
        "human_approval_required": true
      }
    },
    {
      "id": "RA-02",
      "title": "UK SME manufacturer energy disclosure",
      "input": {
        "company_name": "Midlands Precision Components Ltd",
        "country": "United Kingdom",
        "sector": "manufacturing",
        "public_documents": ["SECR energy and carbon report"]
      },
      "expected_output": {
        "evidence_summary_includes": ["Scope 1/2 energy use", "SECR disclosure year"],
        "confidence": "strong",
        "human_approval_required": false
      }
    },
    {
      "id": "RA-03",
      "title": "Saudi mining company reserve statement",
      "input": {
        "company_name": "Najd Minerals",
        "country": "Saudi Arabia",
        "sector": "mining",
        "user_question": "What are the publicly disclosed reserve figures?"
      },
      "expected_output": {
