      },
      "expected_output": {
        "evidence_summary_includes": ["water use disclosure"],
        "missing_data_includes": ["methodology for water use figure"],
        "confidence": "weak"
      }
    },
    {
      "id": "RA-05",
      "title": "UK utility public infrastructure investment",
      "input": {
        "company_name": "Northern Water Utilities",
        "country": "United Kingdom",
        "sector": "utilities",
