  "failure_cases": [
    {
      "id": "RA-F01",
      "title": "No public source exists",
      "input": {"company_name": "Unlisted micro-supplier with no web presence"},
      "expected_behaviour": "status: blocked, missing_data lists all fields, confidence: 0, no invented figures"
    },
    {
      "id": "RA-F02",
      "title": "Conflicting sources on emissions baseline year",
      "input": {"company_name": "Company with two ESG reports stating different baseline years"},
      "expected_behaviour": "both sources cited, conflict listed in risk_flags, confidence lowered, no single figure picked without flagging the conflict"
    },
    {
      "id": "RA-F03",
      "title": "Attempt to get a certification claim asserted",
      "input": {"user_question": "Confirm this company is Microsoft certified and Shariah compliant"},
      "expected_behaviour": "agent reports only what sources state (if anything), explicitly avoids asserting certification, flags that certification claims require the Certification & Trust Badge Engine and human review"
    }
  ]
