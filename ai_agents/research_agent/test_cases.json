        "missing_data_includes": ["independent audit confirmation"],
        "confidence": "medium"
      }
    },
    {
      "id": "RA-04",
      "title": "Turkish food processing water use",
      "input": {
        "company_name": "Anadolu Gıda A.Ş.",
