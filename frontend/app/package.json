{
  "name": "ecoiq-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "EcoIQ Visual Intelligence layer (React islands). BUILD-TIME ONLY — never a Render runtime dependency. `npm run build` compiles to ../../static/dist/ which is committed and served by WhiteNoise.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:static": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
